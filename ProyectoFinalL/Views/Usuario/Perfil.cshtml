@model DataB.Usuario
@{
    ViewBag.Title = "Mi Perfil";
}

<div class="main-screen-wrapper">
    <div id="card-container" class="card-flip-container @(ViewBag.Error != null ? "flipped" : "")">

        <div class="card-front game-menu-container text-center">
            <div class="game-header text-uppercase">DATOS DEL JUGADOR</div>

            <div class="menu-options px-4 mt-4">
                <label class="game-label">NOMBRE DE USUARIO ACTUAL:</label>
                <div class="game-data-display">@Model.Nombre</div>

                <div class="mt-4 score-highlight-container">
                    <label class="game-label text-warning">MEJOR PUNTUACION:</label>
                    <div class="game-score-display mt-2">
                        @if (ViewBag.MejorPuntaje == 0 || ViewBag.MejorPuntaje == null)
                        {
                            <span class="text-white">AÚN NO TIENES PUNTAJE</span>
                        }
                        else
                        {
                            <span class="score-value text-white">@ViewBag.MejorPuntaje</span>
                        }
                    </div>
                </div>

                <div class="mt-5 pt-3">
                    <button type="button" onclick="flipCard('front')" class="btn-game btn-save">EDITAR PERFIL</button>
                    <a href="@Url.Action("Index", "Home")" class="btn-game btn-cancel mt-3">VOLVER AL INICIO</a>
                </div>
            </div>
        </div>

        <div class="card-back game-menu-container text-center">
            <div class="game-header text-uppercase">EDITAR PERFIL</div>

            <div class="menu-options px-4 mt-4">
                @using (Html.BeginForm("GuardarPerfil", "Usuario", FormMethod.Post, new { @class = "form-cascada" }))
                {
                    <label class="game-label">NUEVO NOMBRE:</label>
                    <input type="text" name="nuevoNombre" value="@Model.Nombre" class="game-input text-center" required maxlength="15" />
                    <button type="submit" class="btn-game btn-save btn-sm mt-3 mb-3">GUARDAR NOMBRE</button>
                }

                <div class="separator"></div>

                @using (Html.BeginForm("CambiarContrasena", "Usuario", FormMethod.Post, new { id = "formPass", @class = "form-cascada" }))
                {
                    <label class="game-label mt-3">CAMBIAR CONTRASEÑA:</label>
                    <div class="input-group-vertical">
                        <input type="password" name="nuevaContrasena" placeholder="Nueva Contraseña" class="game-input text-center" required />
                        <input type="password" name="confirmarContrasena" placeholder="Confirmar Contraseña" class="game-input text-center" required />
                    </div>
                    <button type="submit" class="btn-game btn-yellow btn-sm mt-3">ACTUALIZAR CONTRASEÑA</button>
                }

                <div class="mt-4">
                    <button type="button" onclick="flipCard('back')" class="btn-game btn-cancel w-100">VOLVER A MIS DATOS</button>
                </div>
            </div>
        </div>
    </div>

    <div id="modal-error-general" class="modal-overlay" style="display: @(ViewBag.Error != null ? "flex" : "none");">
        <div class="game-menu-container result-box error-style">
            <div class="game-header header-error">¡ATENCIÓN!</div>
            <div class="result-content px-3 text-center">
                <p id="error-text-content" class="error-message">@ViewBag.Error</p>
                <button type="button" onclick="cerrarModalError()" class="btn-game btn-yellow w-100 mt-4">OK</button>
            </div>
        </div>
    </div>
</div>

<style>

    .main-screen-wrapper {
        background-image: url('@Url.Content("~/Content/images/image_13.png")');
        background-size: cover; background-position: center; min-height: 100vh;
        display: flex; justify-content: center; align-items: center; perspective: 1500px;
    }

    .card-flip-container {
        width: 100%; max-width: 450px; position: relative;
        transition: transform 0.8s cubic-bezier(0.68, -0.55, 0.27, 1.55); transform-style: preserve-3d;
    }
    .flipped { transform: rotateY(180deg); }

    .card-front, .card-back {
        position: absolute; width: 100%; top: 0; left: 0; backface-visibility: hidden;
        background-color: #3498db !important; border: 8px solid #2980b9 !important;
        border-radius: 40px !important; padding: 40px 20px !important; box-shadow: 0 15px 0 #1f618d !important;
    }
    .card-back { transform: rotateY(180deg); position: relative; }

    .game-header { background-color: #ffcc4d; border: 6px solid #e6b800; border-radius: 20px; color: white; text-shadow: 3px 3px 0 #b38f00; padding: 15px; font-weight: 900; font-size: 28px; }
    .game-data-display { background-color: #fff; color: #1f618d; font-size: 24px; font-weight: bold; padding: 15px; border-radius: 15px; border: 4px solid #1f618d; margin-top: 10px; }

    .score-value { font-size: 45px; font-weight: 900; text-shadow: 3px 3px 0 #e6b800; color: white; }
    .game-label { color: white; font-weight: bold; text-shadow: 2px 2px 0 rgba(0,0,0,0.3); }


    .form-cascada { display: flex; flex-direction: column; align-items: center; width: 100%; }
    .input-group-vertical { display: flex; flex-direction: column; gap: 12px; width: 100%; align-items: center; }
    .game-input { width: 90%; background: white; border: 4px solid #1f618d; border-radius: 12px; padding: 10px; font-weight: bold; }

    .btn-game { border: none; border-radius: 15px; font-weight: bold; font-size: 20px; padding: 12px; width: 100%; cursor: pointer; transition: 0.1s; display: block; text-decoration: none !important; }
    .btn-save { background-color: #2ecc71; border-bottom: 8px solid #27ae60; color: white; }
    .btn-yellow { background-color: #ffcc4d; border-bottom: 8px solid #e6b800; color: white; }
    .btn-cancel { background-color: #bdc3c7; border-bottom: 8px solid #95a5a6; color: #2c3e50; }
    .btn-game:active { transform: translateY(4px); border-bottom-width: 2px; }

    .separator { border-top: 4px solid rgba(0,0,0,0.15); width: 100%; margin: 20px 0; }

    .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); display: flex; justify-content: center; align-items: center; z-index: 10000; }
    .error-style { background-color: #e74c3c !important; border: 8px solid #c0392b !important; box-shadow: 0 15px 0 #922b21 !important; border-radius: 40px !important; }
    .header-error { background-color: #ff5e5e !important; border-color: #ff2e2e !important; }
    .error-message { color: white; font-weight: bold; font-size: 20px; margin-top: 15px; }

    @@keyframes popIn {
        0% { transform: scale(0.5); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }
    .result-box { animation: popIn 0.3s cubic-bezier(0.68, -0.55, 0.27, 1.55); }
</style>

<script>
    function flipCard(side) {
        const container = document.getElementById("card-container");
        side === 'front' ? container.classList.add("flipped") : container.classList.remove("flipped");
    }

    function cerrarModalError() {
        document.getElementById("modal-error-general").style.display = "none";
    }

    const formPass = document.getElementById("formPass");
    if (formPass) {
        formPass.onsubmit = function (e) {
            const pass = document.getElementsByName("nuevaContrasena")[0].value;
            const confirm = document.getElementsByName("confirmarContrasena")[0].value;

            if (pass !== confirm) {
                e.preventDefault();
                document.getElementById("error-text-content").innerText = "¡Las contraseñas no coinciden, @Session["Usuario"]!";
                document.getElementById("modal-error-general").style.display = "flex";
            }
        };
    }
</script>