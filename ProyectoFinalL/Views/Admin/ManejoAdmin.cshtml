@model ProyectoFinalL.Models.AdminViewModel

<div class="main-screen-wrapper">
    <div class="game-menu-container" style="max-width: 850px;">
        <a href="@Url.Action("Index", "Game")" class="btn-close-x">X</a>

        <div class="game-header" style="color: #2c3e50; margin-bottom: 20px; font-size: 24px;">
            PANEL DE CONTROL ADMIN
        </div>

        <div class="info-item" style="border: 2px dashed #ffcc4d; background: rgba(255,255,255,0.1);">
            <span>⌛ TIEMPO DEL JUEGO:</span>
            <form action="@Url.Action("ActualizarTiempo", "Admin")" method="post" style="display: flex; gap: 10px;">
                <input type="number" name="nuevoTiempo" value="@ViewBag.TiempoActual"
                       style="width: 70px; border-radius: 10px; border: none; text-align: center; font-weight: bold;" />
                <button type="submit" class="btn-game btn-yellow" style="padding: 5px 15px; font-size: 14px;">GUARDAR</button>
            </form>
        </div>

        <div style="background: white; border-radius: 20px; padding: 15px; color: #2c3e50; margin-top: 15px;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 2px solid #3498db; color: #3498db; font-size: 14px;">
                        <th style="padding: 10px; text-align: left;">JUGADOR</th>
                        <th style="padding: 10px;">PUNTOS</th>
                        <th style="padding: 10px;">CONTRASEÑA</th>
                        <th style="padding: 10px;">ACCIÓN</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Usuarios)
                    {
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 10px; text-align: left;">
                                <div style="font-weight: bold; color: #2980b9;">@user.Nombre</div>
                                <div style="font-size: 10px; color: #95a5a6;">ID: @user.IdUsuario</div>
                            </td>

                            <td style="padding: 10px;">
                                <form action="@Url.Action("ActualizarPuntaje", "Admin")" method="post" style="display: flex; gap: 4px; justify-content: center;">
                                    <input type="hidden" name="idUsuario" value="@user.IdUsuario" />
                                    <input type="number" name="nuevosPuntos"
                                           value="@(Model.Puntajes.Where(p => p.IdUsuario == user.IdUsuario).OrderByDescending(p => p.Puntos).Select(p => p.Puntos).FirstOrDefault())"
                                           style="width: 65px; border: 1.5px solid #2ecc71; border-radius: 8px; text-align: center; font-weight: bold;" />
                                    <button type="submit" class="btn-blue-light" style="border: none; border-radius: 5px; padding: 2px 8px; cursor: pointer;">Ok</button>
                                </form>
                            </td>

                            <td style="padding: 10px;">
                                <form action="@Url.Action("EditarPassword", "Admin")" method="post" style="display: flex; gap: 4px; justify-content: center;">
                                    <input type="hidden" name="idUsuario" value="@user.IdUsuario" />
                                    <input type="text" name="nuevaPassword" placeholder="Nueva..."
                                           style="width: 90px; border: 1.5px solid #3498db; border-radius: 8px; padding: 2px 5px; font-size: 12px;" />
                                    <button type="submit" class="btn-blue-light" style="border: none; border-radius: 5px; padding: 2px 8px; cursor: pointer;">Ok</button>
                                </form>
                            </td>

                            <td style="padding: 10px;">
                                <form action="@Url.Action("EliminarUsuario", "Admin")" method="post" onsubmit="return confirm('¿Borrar a @user.Nombre?')">
                                    <input type="hidden" name="idUsuario" value="@user.IdUsuario" />
                                    <button type="submit" style="background: #e74c3c; color: white; border: none; border-radius: 8px; padding: 6px; font-weight: bold; font-size: 10px; cursor: pointer;">BORRAR</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .main-screen-wrapper {
        background-image: url('@Url.Content("~/Content/images/image_13.png")');
        background-size: cover; background-position: center;
        display: flex; justify-content: center; align-items: center;
        min-height: 100vh; width: 100vw; position: fixed; top: 0; left: 0;
    }

    .game-menu-container {
        background-color: #3498db !important;
        border: 8px solid #2980b9 !important;
        box-shadow: 0 12px 0 #1f618d !important;
        border-radius: 40px; padding: 30px; position: relative;
        color: white; text-align: center;
    }

    .btn-close-x {
        position: absolute; top: -15px; right: -15px;
        width: 45px; height: 45px; background-color: #e74c3c;
        border: 4px solid #ffffff; border-radius: 50%;
        display: flex; justify-content: center; align-items: center;
        color: white !important; font-size: 26px; font-weight: bold;
        text-decoration: none; z-index: 1000; box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    }

    .game-header { background-color: #ffcc4d; border: 5px solid #e6b800; border-radius: 15px; font-weight: 900; padding: 10px; }
    .btn-game { border: none; border-radius: 20px; padding: 12px; font-weight: 900; cursor: pointer; text-decoration: none; display: block; }
    .btn-yellow { background-color: #ffcc4d; color: white; border-bottom: 6px solid #e6b800; }
    .info-item { background: rgba(0,0,0,0.2); margin: 8px 0; padding: 12px; border-radius: 15px; display: flex; justify-content: space-between; font-weight: bold; align-items: center; }
</style>