@model DataB.Puntaje
@{
    var nivelParaJS = ViewBag.Nivel;
    var nombreJugador = ViewBag.NombreUsuario ?? "Invitado";
    ViewBag.Title = "Math Riddles - Jugando";
}

<div class="main-screen-wrapper">

    <div id="contenedor-juego" class="game-menu-container">
        <a href="@Url.Action("Index", "Home")" class="btn-close-x" title="Salir">×</a>

        <div class="game-header text-uppercase">MODO: @nivelParaJS</div>

        <div id="pantalla-juego" class="mt-4">
            <h1 id="operacion" class="math-question">Cargando...</h1>
            <div class="form-group mx-auto" style="max-width: 200px;">
                <input type="number" id="respuestaUsuario" class="form-control auth-input text-center" placeholder="?">
            </div>
            <button type="button" class="btn-game btn-yellow w-100 mt-3" id="btnResponder">RESPONDER</button>
        </div>

        <div class="row mt-4 stats-row">
            <div class="col-6"><h5>PUNTOS: <span id="puntos" class="text-success font-weight-bold">0</span></h5></div>
            <div class="col-6"><h5>TIEMPO: <span id="tiempo" class="text-danger font-weight-bold">30</span>s</h5></div>
        </div>
    </div>

    <div id="modal-error-general" class="modal-overlay" style="display:none;">
        <div class="game-menu-container error-style shadow-lg">
            <div class="game-header header-error">¡ATENCIÓN!</div>
            <div class="result-content px-3 text-center">
                <p id="error-text-content" class="error-message mt-4 font-weight-bold"></p>
                <a href="@Url.Action("Index", "Home")" class="btn-game btn-yellow w-100 mt-4">OK, ENTENDIDO</a>
            </div>
        </div>
    </div>

    <div id="modal-resultados" class="modal-overlay" style="display:none;">
        <div class="game-menu-container result-box shadow-lg">
            <div class="game-header">¡NIVEL TERMINADO!</div>
            <div class="result-content px-3 mt-3">
                <div class="info-item">
                    <span>JUGADOR:</span>
                    <span>@nombreJugador</span>
                </div>
                <div class="info-item score-highlight">
                    <span>PUNTOS:</span>
                    <span id="puntos-final">0</span>
                </div>
                <div class="button-group-vertical mt-4">
                    <button onclick="location.reload()" class="btn-game btn-yellow w-100 mb-2">REINICIAR</button>
                    <a href="@Url.Action("Index", "Home")" class="btn-game btn-blue-light w-100">INICIO</a>
                </div>
            </div>
        </div>
    </div>

</div>

<style>

    .main-screen-wrapper {
        background-image: url('@Url.Content("~/Content/images/image_13.png")');
        background-size: cover; background-position: center;
        display: flex; justify-content: center; align-items: center;
        min-height: 100vh; width: 100vw; position: fixed; top: 0; left: 0;
    }

    
    .game-menu-container {
        background-color: #3498db !important;
        border: 8px solid #2980b9 !important;
        box-shadow: 0 12px 0 #1f618d !important;
        border-radius: 40px; padding: 30px; position: relative;
        max-width: 450px; width: 90%; color: white; text-align: center;
    }

 
    .btn-close-x {
        position: absolute;
        top: -15px; right: -15px; 
        width: 45px; height: 45px;
        background-color: #e74c3c; 
        border: 4px solid #ffffff; 
        border-radius: 50%;
        display: flex; justify-content: center; align-items: center;
        color: white !important; font-size: 26px; font-weight: bold;
        text-decoration: none; z-index: 1000;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        transition: 0.2s;
    }

    .btn-close-x:hover { transform: scale(1.1); background-color: #ff2e2e; }


    .modal-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.85); 
        display: flex; justify-content: center; align-items: center;
        z-index: 9999;
    }


    .error-style {
        background-color: #e74c3c !important;
        border-color: #c0392b !important;
        box-shadow: 0 12px 0 #922b21 !important;
        animation: popIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .header-error { background-color: #ff5e5e !important; border-color: #fff !important; }

    .error-message { font-size: 20px; color: white; line-height: 1.4; }

    @@keyframes popIn {
        from { transform: scale(0.5); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }


    .game-header { background-color: #ffcc4d; border: 5px solid #e6b800; border-radius: 15px; font-weight: 900; padding: 10px; }
    .math-question { font-size: 80px; font-weight: bold; margin: 20px 0; }
    .btn-game { border: none; border-radius: 20px; padding: 12px; font-weight: 900; cursor: pointer; text-decoration: none; display: block; }
    .btn-yellow { background-color: #ffcc4d; color: white; border-bottom: 6px solid #e6b800; }
    .btn-blue-light { background-color: #81d4fa; color: white; border-bottom: 6px solid #4fc3f7; }
    .info-item { background: rgba(0,0,0,0.2); margin: 8px 0; padding: 12px; border-radius: 15px; display: flex; justify-content: space-between; font-weight: bold; }
</style>

<script>
    let puntos = 0;
    let tiempo = 30;

    let nivelActual = "@(ViewBag.Nivel)".toUpperCase();
    let resultadoCorrecto;

    function generarOperacion() {
        let n1, n2;

     
        document.getElementById("respuestaUsuario").value = "";

        if (nivelActual.includes("FACIL")) {
            n1 = Math.floor(Math.random() * 10) + 1;
            n2 = Math.floor(Math.random() * 10) + 1;
            resultadoCorrecto = n1 + n2;
            document.getElementById("operacion").innerText = n1 + " + " + n2;
        }
        else if (nivelActual.includes("INTERMEDIO")) {
            n1 = Math.floor(Math.random() * 20) + 10;
            n2 = Math.floor(Math.random() * 10) + 1;
            resultadoCorrecto = n1 - n2;
            document.getElementById("operacion").innerText = n1 + " - " + n2;
        }
        else if (nivelActual.includes("DIFICIL")) {
            n1 = Math.floor(Math.random() * 12) + 2;
            n2 = Math.floor(Math.random() * 10) + 2;
            resultadoCorrecto = n1 * n2;
            document.getElementById("operacion").innerText = n1 + " × " + n2;
        }

        document.getElementById("respuestaUsuario").focus();
    }

    function verificar() {
        let input = document.getElementById("respuestaUsuario");
        let val = parseInt(input.value);

        if (val === resultadoCorrecto) {
         
            if(nivelActual.includes("FACIL")) puntos += 10;
            else if(nivelActual.includes("INTERMEDIO")) puntos += 20;
            else puntos += 25;

            document.getElementById("puntos").innerText = puntos;
            generarOperacion();
        } else {
          
            input.value = "";
            input.focus();
        }
    }

    async function finalizarJuego() {
        if (puntos > 0) {
            try {

                const response = await fetch('/Game/GuardarPuntaje', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ puntos: puntos, dificultad: nivelActual })
});

                const res = await response.json();
                if (res.success) {
                    console.log("¡Puntajes guardados con éxito!");

                }
            } catch (err) {
                console.error("Error en la conexión:", err);
            }

            document.getElementById("puntos-final").innerText = puntos;
            document.getElementById("modal-resultados").style.display = "flex";
        }
    }

    document.addEventListener("DOMContentLoaded", function() {
        generarOperacion();

        document.getElementById("btnResponder").onclick = verificar;
        document.getElementById("respuestaUsuario").onkeyup = (e) => { if (e.key === "Enter") verificar(); };

        let timer = setInterval(() => {
            tiempo--;
            document.getElementById("tiempo").innerText = tiempo;
            if (tiempo <= 0) { clearInterval(timer); finalizarJuego(); }
        }, 1000);
    });
</script>