@{
    ViewBag.Title = "MathRiddles - Acceso";
}

<div class="super-container-game">

    <div class="auth-card-flipper-game @(ViewBag.Modo == "registro" ? "register-active" : "")">

        <div class="auth-card-game auth-front-game">
            <div class="game-header-banner">MathRiddles</div>

            <form action="@Url.Action("Login", "Auth")" method="post">
                <div class="form-group-game">
                    <label>Correo Electrónico</label>
                    <input type="email" name="correo" class="game-input-style" placeholder="ejemplo@correo.com" required>
                </div>

                <div class="form-group-game">
                    <label>Contraseña</label>
                    <input type="password" name="password" class="game-input-style" placeholder="********" required>
                </div>

                <button type="submit" class="btn-game-purple-style">Ingresar</button>
            </form>

            @if (ViewBag.Error != null && ViewBag.Modo != "registro")
            {
                <div class="alert-game-error">@ViewBag.Error</div>
            }

            <p class="auth-footer-game mt-4">
                ¿No tienes cuenta? <a href="#" id="showRegister" class="yellow-link-game">Regístrate aquí</a>
            </p>
        </div>

        <div class="auth-card-game auth-back-game">
            <div class="game-header-banner">Registrarse</div>

            <form action="@Url.Action("Register", "Auth")" method="post">
                <div class="form-group-game">
                    <label>Nombre de Usuario</label>
                    <input type="text" name="nombre" class="game-input-style" placeholder="Tu Apodo" required>
                </div>

                <div class="form-group-game">
                    <label>Correo Electrónico</label>
                    <input type="email" name="correo" class="game-input-style" placeholder="tu@correo.com" required>
                </div>

                <div class="form-group-game">
                    <label>Contraseña (Mín. 5)</label>
                    <input type="password" name="password" class="game-input-style" placeholder="********" minlength="5" required>
                </div>

                <button type="submit" class="btn-game-purple-style">Crear Cuenta</button>
            </form>

            @if (ViewBag.Error != null && ViewBag.Modo == "registro")
            {
                <div class="alert-game-error">@ViewBag.Error</div>
            }

            <p class="auth-footer-game mt-4">
                ¿Ya tienes cuenta? <a href="#" id="showLogin" class="yellow-link-game">Inicia sesión aquí</a>
            </p>
        </div>
    </div>
</div>

<style>
   
    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        overflow: hidden; 
        background-color: #2c3e50; 
        font-family: 'Arial Rounded MT Bold', Arial; 
    }
    

    .super-container-game {
        display: flex;
        justify-content: center; 
        align-items: center; 
        height: 100vh; 
        width: 100vw;
        perspective: 1500px; 
    }

    .auth-card-flipper-game {
        position: relative;
        width: 90%; 
        max-width: 420px; 
        height: 600px;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        transform-style: preserve-3d;
    }

    .register-active {
        transform: rotateY(180deg);
    }

    .auth-card-game {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: #3498db; 
        border-radius: 30px; 
        padding: 30px;
        box-sizing: border-box; 

        border: 5px solid #2980b9;
        box-shadow: 0 10px 0 #21618C;

        backface-visibility: hidden;
        -webkit-backface-visibility: hidden;
    }

    .game-header-banner {
        background-color: #f1c40f;
        border-radius: 15px;
        padding: 15px;
        text-align: center;
        color: white;
        font-size: 28px;
        font-weight: bold;
        text-shadow: 2px 2px #b7950b;
        border-bottom: 5px solid #d4ac0d; 
        margin-bottom: 30px;
    }

    .form-group-game {
        margin-bottom: 20px;
        color: white; 
    }

        .form-group-game label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
        }

    .game-input-style {
        width: 100%;
        background-color: white;
        border-radius: 15px;
        border: none;
        padding: 15px;
        box-sizing: border-box;
        color: #2c3e50;
        font-weight: bold;
    }

    .btn-game-purple-style {
        width: 100%;
        background-color: #6c5ce7; 
        color: white;
        border: none;
        border-radius: 15px;
        padding: 18px;
        font-weight: bold;
        font-size: 16px;
        cursor: pointer;
        border-bottom: 5px solid #4834d4;
        transition: 0.2s;
        margin-top: 10px;
    }

        .btn-game-purple-style:active {
            transform: translateY(3px);
            border-bottom-width: 2px;
        }

    .auth-footer-game {
        text-align: center;
        color: white;
        font-size: 14px;
    }

    .yellow-link-game {
        color: #f1c40f; 
        text-decoration: underline;
        font-weight: bold;
    }

    .alert-game-error {
        background-color: #e74c3c;
        color: white;
        border-radius: 10px;
        padding: 10px;
        margin-top: 15px;
        text-align: center;
    }

    .auth-front-game {
        z-index: 2;
        transform: rotateY(0deg);
    }

    .auth-back-game {
        transform: rotateY(180deg);
    }

</style>

<script>
    document.getElementById('showRegister').addEventListener('click', function (e) {
        e.preventDefault();
        document.querySelector('.auth-card-flipper-game').classList.add('register-active');
    });

    document.getElementById('showLogin').addEventListener('click', function (e) {
        e.preventDefault();
        document.querySelector('.auth-card-flipper-game').classList.remove('register-active');
    });
</script>