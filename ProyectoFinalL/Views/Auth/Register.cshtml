@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <title>MathRiddles - Registro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #f4f7f6;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
        }

        .register-card {
            width: 400px;
            padding: 2rem;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            background: white;
        }

        .btn-custom {
            background: #6c63ff;
            color: white;
            border-radius: 25px;
        }
    </style>
</head>
<body>
    <div class="register-card">
        <h2 class="text-center mb-4">Crear Cuenta</h2>
        @using (Html.BeginForm("Register", "Auth", FormMethod.Post))
        {
            <div class="mb-3">
                <label class="form-label">Correo Electrónico</label>
                <input type="email" name="correo" class="form-control" required placeholder="tu@correo.com">
            </div>
            <div class="mb-3">
                <label class="form-label">Nombre De Usuario</label>
                <input type="text" name="nombre" placeholder="Nombre de usuario (Apodo)" class="form-control" required />
            </div>

                <div class="mb-4">
                    <label class="form-label">Contraseña (5 dígitos)</label>
                    <input type="password" name="password" class="form-control" minlength="5" title="Mínimo 5 caracteres" required placeholder="Contraseña">

                </div>
                <button type="submit" class="btn btn-custom w-100 mb-3">Registrarme</button>
                <p class="text-center small">¿Ya tienes cuenta? <a href="@Url.Action("Login", "Auth")">Inicia sesión</a></p>
                }
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger mt-3 py-2 small text-center">@ViewBag.Error</div>
                }
            </div>
</body>
</html>